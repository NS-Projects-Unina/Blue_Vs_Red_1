<group name="local,ctf">

  <rule id="100001" level="10">
    <if_sid>31100</if_sid> 
    <match type="pcre2">(?i)nmap|nikto</match> 
    <description>CTF ALERT: Tentativo di scanning web su DVWA rilevato </description>
    <group>scan,recon,web,attack</group>
    <mitre>
      <id>T1595.002</id> 
    </mitre>
  </rule>

  <rule id="100002" level="10" frequency="15" timeframe="5">
    <if_matched_sid>31101</if_matched_sid>
    <same_source_ip />
    <description>Possibile web port/path scanning: molte richieste HTTP dallo stesso IP</description>
    <group>scan,web,recon</group>
  </rule>

  <rule id="100003" level="10" frequency="10" timeframe="5">
    <if_matched_sid>31120</if_matched_sid>
    <same_source_ip />
    <description>Scansione web aggressiva: molti 404 consecutivi dallo stesso IP</description>
    <group>scan,web,recon</group>
  </rule>

  <rule id="100004" level="12">
    <if_group>web|apache</if_group>
    <match>Nikto|sqlmap|nessus|openvas|masscan|ZAP|w3af|acunetix|dirbuster|gobuster|wfuzz</match>
    <description>User-Agent di scanner automatico rilevato nelle richieste HTTP</description>
    <group>scan,web,recon</group>
  </rule>

  <rule id="100006" level="11">
    <if_sid>1002</if_sid> <match>NET-SCAN:</match>
    <description>CTF ALERT: Rilevato pacchetto di network scanning TCP SYN (nmap -sS)</description>
    <group>scan,network</group>
  </rule>


 <!-- Privilege escalation via journal/command output -->
  <rule id="100050" level="12">
    <if_sid>530</if_sid>
    <match>sudo-journal-monitor</match>
    <regex>sudo.*COMMAND|sudo.*authentication failure|sudo.*incorrect password</regex>
    <description>Privilege escalation: attività sudo rilevata via journal</description>
    <group>privesc,sudo</group>
    <mitre><id>T1548.003</id></mitre>
  </rule>

  <rule id="100051" level="14" frequency="3" timeframe="60">
    <if_matched_sid>100050</if_matched_sid>
    <match>authentication failure|incorrect password</match>
    <description>Multipli fallimenti sudo: possibile brute-force escalation</description>
    <group>privesc,sudo,brute_force</group>
  </rule>

  <rule id="100020" level="14">
    <if_group>web|apache</if_group>
    <match type="pcre2">(?i)POST.*(upload|hackable/uploads|file_upload|vulnerabilities/upload).*(\.php|\.php5|\.phtml|\.phar|\.shtml)</match>
    <description>Possibile upload di PHP webshell rilevato</description>
    <group>upload,webshell,attack</group>
  </rule>

  <rule id="100021" level="14">
    <if_group>web|apache</if_group>
    <url>/hackable/uploads/|/uploads/|/vulnerabilities/upload</url>
    <match type="pcre2">(?i)"GET </match>
    <description>Esecuzione file in uploads: possibile webshell attiva</description>
    <group>upload,webshell,execution</group>
  </rule>

  <rule id="100042" level="14">
    <if_group>web|apache</if_group>
    <url>/hackable/uploads/|/uploads/|/vulnerabilities/upload</url>
    <match type="pcre2">(?i)"POST </match>
    <description>Upload in corso nella directory uploads</description>
    <group>upload,webshell,execution</group>
  </rule>

  <rule id="100041" level="14">
    <if_sid>31100</if_sid>
    <url>/hackable/uploads/</url>
    <match type="pcre2">(?i)"GET .*\.php</match>
    <description>CTF CRITICAL: Web Shell ESEGUITA su DVWA!</description>
    <group>attack,webshell_execute,active_response</group>
    <mitre><id>T1105</id></mitre>
  </rule>

  <rule id="100023" level="11">
    <if_sid>554</if_sid>
    <match>/var/www/html/hackable/uploads/</match>
    <description>Nuovo file rilevato nella directory uploads (FIM)</description>
    <group>upload,fim</group>
  </rule>

  <rule id="100024" level="15">
    <if_sid>100023</if_sid>
    <match type="pcre2">\.php|\.phtml|\.php5|\.phar|\.sh|\.py|\.pl|\.rb|\.elf|\.cgi</match>
    <description>CRITICO: File pericoloso/eseguibile aggiunto nella cartella uploads (FIM)</description>
    <group>upload,webshell,fim,critical,active_response</group>
  </rule>

  <rule id="100022" level="12">
    <if_group>web|apache</if_group>
    <url>/upload|/dvwa</url>
    <match type="pcre2">(?i)\.sh|\.py|\.pl|\.rb|\.exe|\.elf</match>
    <description>Upload di file eseguibile sospetto</description>
    <group>upload,execution</group>
  </rule>

  <rule id="100040" level="12">
    <if_sid>31100</if_sid>
    <url>/hackable/uploads/</url>
    <match type="pcre2">(?i)\.php|\.phtml|\.php3|\.php4|\.php5|\.phar|\.sh|\.py|\.pl</match>
    <description>CTF ALERT: Rilevato caricamento (POST) di un file eseguibile/Web Shell su DVWA</description>
    <group>attack,file_upload,webshell,recon</group>
    <mitre>
      <id>T1505.003</id>
    </mitre>
  </rule>



  
  <!-- ══════════════════════════════════════════════════════════════
     REVERSE SHELL PHP (pentestmonkey-style)
     Tecnica: connessione TCP outbound da processo Apache/PHP
     MITRE: T1059.004 (Unix Shell), T1071.001 (Web Protocol C2)
     ══════════════════════════════════════════════════════════════ -->

  <!-- 1. Rilevazione upload del file .php nella uploads dir
       (già coperto da 100020/100024 ma aggiungiamo il content-match
        per le funzioni caratteristiche nel body della richiesta POST) -->
  <rule id="100070" level="14">
    <if_group>web|apache</if_group>
    <match type="pcre2">(?i)fsockopen|proc_open|stream_select|pcntl_fork|posix_setsid</match>
    <description>REVERSE SHELL: funzioni PHP pericolose rilevate nel log Apache (possibile upload reverse shell)</description>
    <group>upload,webshell,reverseshell,attack</group>
    <mitre><id>T1059.004</id></mitre>
  </rule>

    <!-- Esecuzione reverse shell: curl/browser su .php in uploads
       Usa solo <match> sul full_log perché <url> fallisce
       se DVWA è installato in /dvwa/ o con path diverso -->
  <rule id="100071" level="14">
    <if_sid>31100</if_sid>
    <match type="pcre2">(?i)"GET .*hackable/uploads/.*\.php[^"]*" [245]\d\d</match>
    <description>REVERSE SHELL: esecuzione .php in uploads rilevata (curl o browser)</description>
    <group>webshell,reverseshell,execution</group>
    <mitre><id>T1059.004</id></mitre>
  </rule>


  <!-- 5. Processo figlio sospetto di Apache: /bin/sh spawned da www-data
       proc_open() crea un processo figlio. Il wodle netstat non lo vede
       ma il rootcheck/syscollector di Wazuh può rilevarlo via audit -->
  <rule id="100074" level="15">
    <if_sid>530</if_sid>
    <match>process-monitor</match>
    <description>REVERSE SHELL: shell interattiva (sh/bash) spawnata dall'utente web (www-data)</description>
    <group>webshell,reverseshell,execution</group>
    <mitre><id>T1059.004</id></mitre>
  </rule>

    <!-- Copertura aggiuntiva: qualsiasi status code, anche 500
       La reverse shell PHP va spesso in timeout e Apache risponde 500 -->
  <rule id="100075" level="14">
    <if_sid>31100</if_sid>
    <match type="pcre2">(?i)"GET .*hackable/uploads/.*\.php</match>
    <description>REVERSE SHELL: GET su file PHP in uploads (qualsiasi risposta HTTP)</description>
    <group>webshell,reverseshell,execution</group>
    <mitre><id>T1059.004</id></mitre>
  </rule>

</group>