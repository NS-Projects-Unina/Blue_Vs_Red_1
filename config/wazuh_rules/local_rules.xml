<group name="local,ctf">

  <rule id="100001" level="10">
    <if_sid>31100</if_sid> 
    <match type="pcre2">(?i)nmap|nikto</match> 
    <description>CTF ALERT: Tentativo di scanning web su DVWA rilevato tramite tool noto (Nmap/Nikto)</description>
    <group>scan,recon,web,attack</group>
    <mitre>
      <id>T1595.002</id> 
    </mitre>
  </rule>

  <rule id="100002" level="10" frequency="15" timeframe="5">
    <if_matched_sid>31101</if_matched_sid>
    <same_source_ip />
    <description>Possibile web port/path scanning: molte richieste HTTP dallo stesso IP</description>
    <group>scan,web,recon</group>
  </rule>

  <rule id="100003" level="10" frequency="10" timeframe="5">
    <if_matched_sid>31120</if_matched_sid>
    <same_source_ip />
    <description>Scansione web aggressiva: molti 404 consecutivi dallo stesso IP</description>
    <group>scan,web,recon</group>
  </rule>

  <rule id="100004" level="12">
    <if_group>web|apache</if_group>
    <match>Nikto|sqlmap|nessus|openvas|masscan|ZAP|w3af|acunetix|dirbuster|gobuster|wfuzz</match>
    <description>User-Agent di scanner automatico rilevato nelle richieste HTTP</description>
    <group>scan,web,recon</group>
  </rule>

  <rule id="100006" level="11">
    <if_sid>1002</if_sid> <match>NET-SCAN:</match>
    <description>CTF ALERT: Rilevato pacchetto di network scanning TCP SYN (nmap -sS)</description>
    <group>scan,network</group>
  </rule>


  <rule id="100010" level="12">
    <if_sid>5402</if_sid>
    <match>sudo</match>
    <description>Uso di sudo da parte di un utente: possibile privilege escalation</description>
    <group>privesc,sudo</group>
  </rule>

  <rule id="100011" level="13" frequency="5" timeframe="60">
    <if_matched_sid>5401</if_matched_sid>
    <description>Multipli tentativi sudo falliti: possibile brute-force privilege escalation</description>
    <group>privesc,sudo,brute_force</group>
  </rule>

  <rule id="100012" level="12">
    <if_group>syscheck</if_group>
    <field name="file">/usr/bin/passwd|/usr/bin/sudo|/bin/su|/usr/bin/pkexec</field>
    <match>modified</match>
    <description>Modifica a binario SUID critico rilevata: possibile privilege escalation</description>
    <group>privesc,suid,integrity</group>
  </rule>

  <rule id="100013" level="10">
    <if_sid>5303</if_sid>
    <description>Cambio utente tramite su: monitorare per escalation</description>
    <group>privesc,su</group>
  </rule>

  <rule id="100014" level="14">
    <if_group>syscheck</if_group>
    <field name="file">/etc/passwd|/etc/shadow|/etc/sudoers</field>
    <description>Modifica critica a file di autenticazione: alta priorità</description>
    <group>privesc,integrity,authentication</group>
  </rule>

  <rule id="100015" level="11">
    <if_group>audit</if_group>
    <match>type=SYSCALL.*open.*shadow|type=PATH.*shadow</match>
    <description>Tentativo di accesso a /etc/shadow rilevato</description>
    <group>privesc,audit</group>
  </rule>

  <rule id="100016" level="11">
    <if_group>syscheck</if_group>
    <field name="file">/etc/cron|/var/spool/cron</field>
    <description>Modifica a crontab: possibile persistence o escalation</description>
    <group>privesc,persistence</group>
  </rule>


  <rule id="100020" level="14">
    <if_group>web|apache</if_group>
    <url>/upload|/dvwa/upload|/hackable/uploads|/file_upload|/vulnerabilities/upload</url>
    <match>\.php|\.php5|\.phtml|\.phar|\.shtml</match>
    <description>Possibile upload di PHP webshell rilevato</description>
    <group>upload,webshell,attack</group>
  </rule>

  <rule id="100021" level="14">
    <if_group>web|apache</if_group>
    <url>/hackable/uploads/|/uploads/|/vulnerabilities/upload</url>
    <match>GET</match>
    <description>Accesso/esecuzione di file nella directory uploads: possibile webshell attiva</description>
    <group>upload,webshell,execution</group>
  </rule>
  
  <rule id="100042" level="14">
    <if_group>web|apache</if_group>
    <url>/hackable/uploads/|/uploads/|/vulnerabilities/upload</url>
    <match>POST</match>
    <description>Accesso/esecuzione di file nella directory uploads: possibile webshell attiva</description>
    <group>upload,webshell,execution</group>
  </rule>

  <rule id="100022" level="12">
    <if_group>web|apache</if_group>
    <url>/upload|/dvwa</url>
    <match>\.sh|\.py|\.pl|\.rb|\.exe|\.elf</match>
    <description>Upload di file eseguibile sospetto</description>
    <group>upload,execution</group>
  </rule>

  <rule id="100023" level="11">
    <if_group>syscheck</if_group>
    <field name="file">/var/www/html/hackable/uploads/|/var/www/html/dvwa/hackable/uploads/</field>
    <match>added</match>
    <description>Nuovo file rilevato nella directory uploads (FIM)</description>
    <group>upload,fim</group>
  </rule>

  <rule id="100024" level="15">
    <if_sid>100023</if_sid>
    <field name="file">\.php$|\.phtml$|\.php5$</field>
    <description>CRITICO: file PHP aggiunto nella cartella uploads (webshell?)</description>
    <group>upload,webshell,fim,critical</group>
  </rule>

  <rule id="100040" level="12">
    <if_sid>31100</if_sid>
    <url>/hackable/uploads/</url>
    <match type="pcre2">(?i)\.php|\.phtml|\.php3|\.php4|\.php5|\.phar|\.sh|\.py|\.pl</match>
    <description>CTF ALERT: Rilevato caricamento (POST) di un file eseguibile/Web Shell su DVWA</description>
    <group>attack,file_upload,webshell,recon</group>
    <mitre>
      <id>T1505.003</id>
    </mitre>
  </rule>

  <rule id="100041" level="14">
    <if_sid>31100</if_sid>
    <url>/hackable/uploads/</url>
    <match type="pcre2">(?i)GET.*\.php</match>
    <description>CTF CRITICAL: Web Shell ESEGUITA con successo su DVWA! Richiesta mitigazione.</description>
    <group>attack,webshell_execute,active_response</group>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>


  <rule id="100030" level="15">
    <if_group>web|apache|syslog</if_group>
    <match>ssl_error|SSL routines|heartbeat|record overflow|HEARTBLEED|bad length</match>
    <description>Possibile sfruttamento Heartbleed (CVE-2014-0160): errore SSL anomalo</description>
    <group>heartbleed,cve-2014-0160,exploit,critical</group>
  </rule>

  <rule id="100031" level="13" frequency="20" timeframe="10">
    <if_matched_sid>100030</if_matched_sid>
    <same_source_ip />
    <description>Multipli errori SSL dallo stesso IP: attacco Heartbleed in corso</description>
    <group>heartbleed,cve-2014-0160,exploit,critical</group>
  </rule>

  <rule id="100032" level="12">
    <if_group>apache</if_group>
    <match>AH01797|AH02042|SSL_ERROR|error:14|tlsv1 alert</match>
    <description>Errore SSL/TLS critico su Apache: potenziale sonda Heartbleed</description>
    <group>heartbleed,ssl,apache</group>
  </rule>

  <rule id="100033" level="11">
    <if_group>syslog|firewall</if_group>
    <match>DPT=443|dport=443</match>
    <description>Connessione HTTPS al proxy: monitorare per possibile Heartbleed</description>
    <group>heartbleed,network,monitor</group>
  </rule>


  <rule id="100090" level="14">
    <if_matched_sid>100001,100002,100003,100004</if_matched_sid>
    <same_source_ip />
    <description>Scanning web confermato: trigger per blocco IP automatico</description>
    <group>scan,active_response,block</group>
  </rule>

  <rule id="100091" level="15">
    <if_sid>100024,100041</if_sid>
    <description>CRITICO: webshell confermata o eseguita – trigger active response</description>
    <group>upload,webshell,active_response,block</group>
  </rule>

  <rule id="100092" level="15">
    <if_sid>100031</if_sid>
    <description>CRITICO: attacco Heartbleed confermato – trigger active response</description>
    <group>heartbleed,active_response,block</group>
  </rule>

</group>